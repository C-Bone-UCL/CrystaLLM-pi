# Copy this file to docker/.env and fill in your values
HF_KEY=your_hf_token_here
WANDB_KEY=your_wandb_key_here

# Required for compose user mapping and avoiding root-owned files in data/ and outputs/
# UID is readonly in bash, so set here directly instead of running: export UID=$(id -u)
UID=1000
GID=1000

# GPU exposure for API container
# Use comma-separated ids like 0,1
# or if you want to expose all GPUs, set to "all"
NVIDIA_VISIBLE_DEVICES=0,1
DOCKER_GPUS=all
